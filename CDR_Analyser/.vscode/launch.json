{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run CDR Analysis (default input)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Run CDR Analysis (custom input)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": [
                "--input",  "${workspaceFolder}/input/${input:CDR filename (e.g. myfile.xlsx)}",
                "--output", "${workspaceFolder}/output/CDR_Report.pdf"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
